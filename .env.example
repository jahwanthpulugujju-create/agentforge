# ══════════════════════════════════════════════════════════════
# Open Code Review — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── PostgreSQL ───────────────────────────────────────────────
# Option A: Full connection string (takes precedence)
DATABASE_URL=postgresql://user:password@localhost:5432/ocrdb

# Option B: Individual params (used if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=ocr
# PGPASSWORD=your-password
# PGDATABASE=ocrdb

# ── Redis (optional — enables BullMQ job queues) ─────────────
# REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# ── AI Providers (system-level fallbacks) ────────────────────
# Users can also supply their own keys via the API Keys settings page.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Features ─────────────────────────────────────────────────
ENABLE_REGISTRATION=true
ENABLE_JOB_QUEUE=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100

# ── CORS (comma-separated allowed origins for production) ─────
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
