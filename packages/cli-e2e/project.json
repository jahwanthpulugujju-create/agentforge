{
  "name": "cli-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cli-e2e/src",
  "projectType": "application",
  "tags": ["scope:cli", "type:e2e"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck", "cli:build"],
      "options": {
        "command": "vitest run --config packages/cli-e2e/vitest.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.typecheck.json",
        "cwd": "{projectRoot}"
      }
    }
  }
}
