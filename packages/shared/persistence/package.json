{
  "name": "@open-code-review/persistence",
  "version": "0.0.0",
  "private": true,
  "description": "Shared persistence + workflow-state layer for Open Code Review (node:sqlite adapter, source-only, non-buildable)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/db/index.ts",
      "source": "./src/db/index.ts",
      "default": "./src/db/index.ts"
    },
    "./state": {
      "types": "./src/state/index.ts",
      "source": "./src/state/index.ts",
      "default": "./src/state/index.ts"
    },
    "./test-support": {
      "types": "./src/db/test-support.ts",
      "source": "./src/db/test-support.ts",
      "default": "./src/db/test-support.ts"
    },
    "./vendor-resume": {
      "types": "./src/vendor-resume.ts",
      "source": "./src/vendor-resume.ts",
      "default": "./src/vendor-resume.ts"
    },
    "./runtime-checks": {
      "types": "./src/runtime-checks.ts",
      "source": "./src/runtime-checks.ts",
      "default": "./src/runtime-checks.ts"
    }
  },
  "dependencies": {
    "@open-code-review/platform": "workspace:*"
  }
}
