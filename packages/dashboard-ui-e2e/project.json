{
  "name": "dashboard-ui-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dashboard-ui-e2e/src",
  "projectType": "application",
  "tags": ["scope:dashboard", "type:e2e", "test:ui"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "dependsOn": ["typecheck", "cli:build"],
      "outputs": ["{workspaceRoot}/dist/.playwright/{projectRoot}"],
      "options": {
        "config": "packages/dashboard-ui-e2e/playwright.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.typecheck.json",
        "cwd": "{projectRoot}"
      }
    }
  }
}
