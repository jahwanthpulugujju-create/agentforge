{
  "name": "@open-code-review/cli",
  "version": "2.3.0",
  "description": "CLI for Open Code Review - Multi-environment setup and progress tracking",
  "type": "module",
  "bin": {
    "ocr": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "code-review",
    "ai",
    "cli",
    "claude",
    "cursor",
    "windsurf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/spencermarx/open-code-review",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "author": "Spencer Marx",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@open-code-review/agents": "workspace:*",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.0.0",
    "cross-spawn": "^7.0.6",
    "log-update": "^7.0.2",
    "ora": "^8.1.1",
    "socket.io": "^4.8",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@open-code-review/config": "workspace:*",
    "@open-code-review/persistence": "workspace:*",
    "@open-code-review/platform": "workspace:*"
  }
}
